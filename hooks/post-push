#!/bin/sh
# ironmunch post-push hook
# Reindexes the GitHub remote repo after each push.
# Install: cp hooks/post-push .git/hooks/post-push && chmod +x .git/hooks/post-push
#
# Git hooks don't inherit your shell environment. To provide GITHUB_TOKEN,
# create ~/.config/ironmunch/env with:
#   GITHUB_TOKEN=ghp_...

# Load ironmunch env file if present (provides GITHUB_TOKEN etc.)
IRONMUNCH_ENV="$HOME/.config/ironmunch/env"
if [ -f "$IRONMUNCH_ENV" ]; then
    # shellcheck disable=SC1090
    . "$IRONMUNCH_ENV"
fi

IRONMUNCH="$(command -v ironmunch)"

if [ -z "$IRONMUNCH" ]; then
    exit 0
fi

# Get the GitHub remote URL and extract owner/repo
REMOTE_URL="$(git remote get-url origin 2>/dev/null)"
if [ -z "$REMOTE_URL" ]; then
    exit 0
fi

# Normalize SSH and HTTPS remote URLs to owner/repo
# ssh: git@github.com:owner/repo.git
# https: https://github.com/owner/repo.git
REPO=$(echo "$REMOTE_URL" | sed -E \
    -e 's|git@github\.com:||' \
    -e 's|https://github\.com/||' \
    -e 's|\.git$||')

if [ -z "$REPO" ]; then
    exit 0
fi

(
    RESULT=$(GITHUB_TOKEN="$GITHUB_TOKEN" "$IRONMUNCH" index-repo "$REPO" --no-ai 2>&1)
    if echo "$RESULT" | grep -q '"success": true'; then
        FILES=$(echo "$RESULT" | grep '"file_count"' | grep -o '[0-9]*')
        SYMBOLS=$(echo "$RESULT" | grep '"symbol_count"' | grep -o '[0-9]*')
        printf "\nironmunch: %s reindexed (%s files, %s symbols)\n" "$REPO" "$FILES" "$SYMBOLS" >&2
    else
        printf "\nironmunch: reindex of %s failed\n" "$REPO" >&2
    fi
) &
