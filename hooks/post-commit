#!/bin/sh
# ironmunch post-commit hook
# Reindexes the current repo after each commit (incremental -- skips unchanged files).
# Install: cp hooks/post-commit .git/hooks/post-commit && chmod +x .git/hooks/post-commit

REPO_ROOT="$(git rev-parse --show-toplevel)"
IRONMUNCH="$(command -v ironmunch)"

if [ -z "$IRONMUNCH" ]; then
    exit 0
fi

(
    RESULT=$("$IRONMUNCH" index "$REPO_ROOT" --no-ai 2>&1)
    if echo "$RESULT" | grep -q '"success": true'; then
        FILES=$(echo "$RESULT" | grep '"file_count"' | grep -o '[0-9]*')
        SYMBOLS=$(echo "$RESULT" | grep '"symbol_count"' | grep -o '[0-9]*')
        printf "\nironmunch: local index updated (%s files, %s symbols)\n" "$FILES" "$SYMBOLS" >&2
    else
        printf "\nironmunch: local reindex failed\n" >&2
    fi
) &
